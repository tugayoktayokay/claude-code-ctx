{
  "limits": {
    "models": {
      "claude-opus-4-7":   { "max": 1000000, "quality_ceiling": 200000 },
      "claude-opus-4-6":   { "max": 200000,  "quality_ceiling": 200000 },
      "claude-sonnet-4-6": { "max": 200000,  "quality_ceiling": 200000 },
      "claude-sonnet-4-5": { "max": 200000,  "quality_ceiling": 200000 },
      "claude-haiku-4-5":  { "max": 200000,  "quality_ceiling": 100000 },
      "default":           { "max": 200000,  "quality_ceiling": 200000 }
    },
    "thresholds": {
      "comfortable": 0.20,
      "watch": 0.40,
      "compact": 0.55,
      "urgent": 0.75,
      "critical": 0.90
    },
    "growth_window": 5,
    "growth_warn": 5000,
    "output_ratio_warn": 0.4,
    "max_entries": 20000
  },
  "watch": {
    "interval_ms": 10000,
    "macos_notifications": true,
    "terminal_status": true
  },
  "daemon": {
    "auto_snapshot_on": [],
    "auto_backup_on": []
  },
  "categories": {
    "schema":   { "words": ["schema","migration","drizzle","prisma","alter table","create table","pgtable","migrate"], "label": "DB/Schema" },
    "api":      { "words": ["route","endpoint","fastify","express","handler","middleware","controller","router"],    "label": "API routes" },
    "mobile":   { "words": ["screen","component","expo","react native","navigation","nativewind","stylesheet"],      "label": "Mobile/UI" },
    "ai":       { "words": ["anthropic","openai","prompt","completion","stream","token","model","claude","gpt"],     "label": "AI integration" },
    "auth":     { "words": ["jwt","auth","login","session","token","passport","guard","permission"],                 "label": "Auth/security" },
    "bug":      { "words": ["hata","error","bug","fix","düzelt","çalışmıyor","undefined","null","exception","crash"],"label": "Bug fix" },
    "refactor": { "words": ["refactor","yeniden","taşı","böl","rename","extract","split","move","reorganize"],       "label": "Refactoring" },
    "infra":    { "words": ["deploy","docker","env","config","server","port","nginx","ssl","ci","cd","pipeline"],     "label": "Infra/DevOps" },
    "test":     { "words": ["test","vitest","jest","spec","assert","expect","mock","coverage","playwright"],          "label": "Tests" },
    "stripe":   { "words": ["stripe","payment","subscription","webhook","billing","iap","apple","google play"],       "label": "Payments" }
  },
  "snapshot": {
    "memory_dir": "{project_dir}/memory",
    "auto_index_update": true,
    "dedup_window_n": 3
  },
  "backup": {
    "enabled": true,
    "dir": "~/.config/ctx/backups",
    "keep_last": 10
  },
  "prune": {
    "default_older_than": "30d",
    "default_keep_last": 20
  },
  "retrieval": {
    "weights": { "category": 0.5, "keyword": 0.3, "recency": 0.2 },
    "recency_half_life_days": 90,
    "min_score": 0.15,
    "top_n": 3,
    "max_candidates": 2000,
    "scan_timeout_ms": 2000
  },
  "stopwords": {
    "tr": ["ve","bir","bu","ne","nasıl","için","ile","mi","mu","ama","fakat","ki","o","şu","da","de","ya","mı","şöyle","böyle"],
    "en": ["the","and","how","what","to","a","an","is","are","was","were","be","or","of","in","on","at","it","this","that"]
  },
  "notes": {
    "roots": [],
    "exclude": ["node_modules", ".git", "dist", "build", ".cache", "vendor", "target"],
    "max_file_kb": 512,
    "follow_symlinks": false
  },
  "hooks": {
    "session_start": { "restore_latest": true, "max_bytes": 8192 },
    "stop":          { "snapshot_on": ["urgent", "critical"], "backup_on": ["critical"] },
    "pre_compact":   { "inject_guidance": true, "respect_user_input": true },
    "post_tool_use": {
      "triggers": [
        { "tool": "Bash", "match": "^git commit", "action": "snapshot" }
      ]
    },
    "user_prompt_submit": {
      "warn_on": [],
      "auto_retrieve": {
        "enabled": true,
        "max_turns": 2,
        "min_score": 0.3,
        "scopes": ["project", "global"]
      }
    }
  }
}
